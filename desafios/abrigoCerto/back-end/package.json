{
  "name": "enchente-backend-simples",
  "version": "1.0.0",
  "description": "API para organizar abrigos em cenarios de enchente usando Node.js, Express e PostgreSQL.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:init": "psql \"$DATABASE_URL\" -f scripts/create-tables.sql"
  },
  "keywords": [
    "node",
    "express",
    "postgresql",
    "enchentes",
    "abrigos"
  ],
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "pg": "^8.13.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
